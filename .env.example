# PromptPerfect Environment Variables
# Copy this file to .env.local and fill in real values

# Optional — Canonical site URL for Open Graph, JSON-LD, and metadata (no trailing slash)
# NEXT_PUBLIC_SITE_URL=https://your-deployment.vercel.app

# Optional — Override default social preview image (absolute URL)
# NEXT_PUBLIC_OG_IMAGE=https://example.com/og.png

# Required — Default LLM provider (Gemini)
GOOGLE_API_KEY=your_google_api_key_here

# Required — Supabase (analytics, history, auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Optional — Only needed if running Supabase migrations locally
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
