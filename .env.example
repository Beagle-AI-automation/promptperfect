# PromptPerfect Environment Variables
# Copy this file to .env.local and fill in real values

# Required — Default LLM provider (Gemini)
GOOGLE_API_KEY=your_google_api_key_here

# Required — Supabase (analytics, history, auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Strongly recommended for OAuth (Google): your deployed app origin, no trailing slash.
# Must match a URL in Supabase → Authentication → URL Configuration → Redirect URLs
# (e.g. https://your-app.vercel.app/auth/callback). If missing, Supabase may redirect to "Site URL".
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Optional — Only needed if running Supabase migrations locally
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
