# PromptPerfect Environment Variables
# Copy this file to .env.local and fill in real values

# Required — Default LLM provider (Gemini)
GOOGLE_API_KEY=your_google_api_key_here

# Optional — Gemini model id (default: gemini-2.5-flash). Change if Google deprecates a model or you hit quotas.
# GEMINI_MODEL=gemini-2.5-flash

# Required — Supabase (analytics, history, auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Required for correct OAuth + email-confirmation + password-reset redirects in production.
# No trailing slash. On Vercel, set this to your deployment URL (same value as Site URL in Supabase).
# Local dev: http://localhost:3000 (add these Redirect URLs in Supabase → Authentication → URL Configuration):
#   http://localhost:3000/auth/callback
#   http://localhost:3000/auth/reset
# Production: https://<your-domain>/auth/callback and https://<your-domain>/auth/reset
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Comma-separated origins allowed to call `/api/optimize-sync` from the browser (CORS).
ALLOWED_ORIGINS=http://localhost:3000,https://promptperfect.vercel.app

# Optional — Only needed if running Supabase migrations locally
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
